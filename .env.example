# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=<generate-a-long-random-string>
DEBUG=False
ALLOWED_HOSTS=<your-app>.railway.app

# ── Database (Supabase) ───────────────────────────────────────────────────────
# DEV:  db.cpzfsgbdiivlskkswqwy.supabase.co  (ibc-dev project)
# PROD: db.wzjgfjuggyndpexocbmt.supabase.co  (ibc-prod project — set on Railway)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<supabase-db-password>
DB_HOST=<project-ref>.supabase.co
DB_PORT=5432

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=<your-gmail>@gmail.com
EMAIL_HOST_PASSWORD=<16-char-google-app-password>
DEFAULT_FROM_EMAIL=Indian Biryani Company <<your-gmail>@gmail.com>

# ── Supabase Storage (invoice file uploads) ──────────────────────────────────
# Supabase dashboard → Project Settings → Storage → S3 Access → Create key
SUPABASE_S3_ACCESS_KEY_ID=<supabase-s3-access-key-id>
SUPABASE_S3_SECRET_ACCESS_KEY=<supabase-s3-secret-key>
SUPABASE_STORAGE_BUCKET=media
SUPABASE_S3_REGION=ap-southeast-1

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_SPACE_API_KEY=<ocr-space-api-key>
